import os
import json
import traceback
from datetime import datetime, timedelta

# ===========================
# CONFIGURATION
# ===========================

# config file path in server directory
CONFIG_FILE = os.path.join(server.directory, 'cloud_backup_config.json')

# GitHub raw URL for templates
GITHUB_TEMPLATES_BASE = "https://raw.githubusercontent.com/kalashnikxvxiii-collab/amscripts/refs/heads/main/cloud-backup/templates"

# Supported providers
SUPPORTED_PROVIDERS = ['gdrive', 'mega', 'filen']

DEFAULT_CONFIG = {
    "enabled": False,
    "provider": None,                       # 'gdrive' | 'mega' | 'filen'
    "credentials_file": None,               # path to credentials or token JSON
    "upload_frequency": "every_backup",     # 'every_backup', 'hourly', 'daily', 'weekly'
    "max_cloud_backups": 10,
    "last_upload": None
}

# ===========================
# UTILITIES
# ===========================

def load_config():
    """Load configuration from JSON. Merge missing keys from DEFAULT_CONFIG."""
    try:
        if os.path.exists(CONFIG_FILE):
            with open(CONFIG_FILE, 'r') as f:
                config = json.load(f)
        else:
            config = DEFAULT_CONFIG.copy()
        # Merge defaults for new keys
        for k, v in DEFAULT_CONFIG.items():
            if k not in config:
                config[k] = v
        return config
    except Exception as e:
        server.log_error("Failed to load config: " + str(e))
        return DEFAULT_CONFIG.copy()

def save_config(config):
    """Save configuration to disk."""
    try:
        with open(CONFIG_FILE, 'w') as f:
            json.dump(config, f, indent=4)
        return True
    except Exception as e:
        server.log_error("Failed to save config: " + str(e))
        server.log_error(traceback.format_exc())
        return False

def should_upload(config):
    """Determine whether it's time to upload according to frequency."""
    if not config.get("enabled", False):
        return False
    freq = config.get("upload_frequency", "every_backup")
    last = config.get("last_upload")
    if freq == "every_backup":
        return True
    if not last:
        return True
    try:
        last_dt = datetime.fromisoformat(last)
        now = datetime.now()
        if freq == "hourly":
            return (now - last_dt) >= timedelta(hours=1)
        if freq == "daily":
            return (now - last_dt) >= timedelta(days=1)
        if freq == "weekly":
            return (now - last_dt) >= timedelta(weeks=1)
    except Exception:
        return True
    return False

# ===========================
# TEMPLATE FETCHING
# ===========================

def fetch_provider_template(provider):
    """
    Download provider template from GitHub raw link.
    Returns local path to saved template, or None on error.
    Template filename pattern: <provider>_template.json
    """
    if provider not in SUPPORTED_PROVIDERS:
        server.log_error(f"Template fetch: Unsupported provider {provider}")
        return None

    template_filename = f"{provider}_template.json"
    url = f"{GITHUB_TEMPLATES_BASE}/{template_filename}"

    try:
        # Try to download using urllib; this assumes server has internet access.
        try:
            import urllib.request as _ur
            server.log(f"Downloading template for {provider} from repository...")
            resp = _ur.urlopen(url, timeout=15)
            content = resp.read().decode('utf-8')
        except Exception as e:
            server.log_error("Failed to download template from GitHub: " + str(e))
            return None

        # Save template next to config with provider-specific filename
        templates_dir = os.path.join(server.directory, "cloud_templates")
        if not os.path.exists(templates_dir):
            os.makedirs(templates_dir)
        local_path = os.path.join(templates_dir, template_filename)
        with open(local_path, 'w') as f:
            f.write(content)

        server.log_success(f"Template saved: {local_path}")
        return local_path

    except Exception as e:
        server.log_error("Error in fetch_provider_template: " + str(e))
        server.log_error(traceback.format_exc())
        return None

# ========================================
# PROVIDER UPLOAD STUBS / IMPLEMENTATIONS
# ========================================

def upload_to_gdrive(backup_path, credentials_file):
    """Upload backup to Google Drive using a service account key file (or other credentials file).
       This function is adapted from your prototype; ensure required packages are installed on the host.
    """
    try:
        from google.oauth2 import service_account
        from googleapiclient.discovery import build
        from googleapiclient.http import MediaFileUpload

        SCOPES = ['https://www.googleapis.com/auth/drive.file']

        # Allow both service account JSON and OAuth client JSON patterns:
        credentials = service_account.Credentials.from_service_account_file(credentials_file, scopes=SCOPES)
        service = build('drive', 'v3', credentials=credentials)

        folder_name = f"minecraft-backups-{server.name}"
        query = f"name='{folder_name}' and mimeType='application/vnd.google-apps.folder' and trashed = false"
        results = service.files().list(q=query, fields='files(id)').execute()
        files = results.get('files', [])

        if files:
            folder_id = files[0]['id']
        else:
            folder_metadata = {'name': folder_name, 'mimeType': 'application/vnd.google-apps.folder'}
            folder = service.files().create(body=folder_metadata, fields='id').execute()
            folder_id = folder['id']

        file_name = os.path.basename(backup_path)
        file_metadata = {'name': file_name, 'parents': [folder_id]}
        media = MediaFileUpload(backup_path, resumable=True)
        file = service.files().create(body=file_metadata, media_body=media, fields='id').execute()

        server.log_success(f"Backup uploaded to Google Drive: {file_name}")
        return True
    except Exception as e:
        server.log_error("Google Drive upload error: " + str(e))
        server.log_error(traceback.format_exc())
        return False

