import json
import os
import subprocess
import urllib.request

# Supported providers (examples - rclone supports 40+ providers!)
SUPPORTED_PROVIDERS = [
    "gdrive",      # Google Drive
    "onedrive",    # Microsoft OneDrive
    "dropbox",     # Dropbox
    "mega",        # Mega
    "filen",       # Filen
    "s3",          # Amazon S3 / MinIO / Backblaze
    "azureblob",   # Azure Blob Storage
    "box",         # Box
    "pcloud",      # pCloud
    # ... rclone supports many more!
]

# GitHub templates base URL
GITHUB_TEMPLATES_BASE = "https://raw.githubusercontent.com/kalashnikxvxiii-collab/amscripts/main/cloud-backup/templates"


# ---------------------------------------------------------
# Config file management
# ---------------------------------------------------------
def get_config_path():
    """Get the config file path in the server directory."""
    return os.path.join(server.directory, "cloud_backup_config.json")


def load_config():
    config_path = get_config_path()
    if not os.path.exists(config_path):
        return {"provider": None, "remote_name": None}
    try:
        with open(config_path, "r", encoding="utf-8") as f:
            return json.load(f)
    except:
        server.log_error("Failed to read config, resetting.")
        return {"provider": None, "remote_name": None}


def save_config(cfg):
    config_path = get_config_path()
    try:
        with open(config_path, "w", encoding="utf-8") as f:
            json.dump(cfg, f, indent=4)
    except Exception as e:
        server.log_error("Failed to save configuration: " + str(e))


# ---------------------------------------------------------
# rclone availability check
# ---------------------------------------------------------
def check_rclone_installed():
    """Check if rclone is installed and available in PATH."""
    try:
        result = subprocess.run(
            ["rclone", "version"],
            capture_output=True,
            text=True,
            timeout=5
        )
        return result.returncode == 0
    except:
        return False


